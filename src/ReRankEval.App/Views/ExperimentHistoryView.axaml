<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:ReRankEval.App.ViewModels"
             xmlns:domain="using:ReRankEval.Domain.Models"
             xmlns:shapes="using:Avalonia.Controls.Shapes"
             x:Class="ReRankEval.App.Views.ExperimentHistoryView"
             x:DataType="vm:ExperimentHistoryViewModel">

    <Grid RowDefinitions="Auto,*" Margin="16">

        <!-- Header -->
        <Grid Grid.Row="0" ColumnDefinitions="Auto,*,Auto,Auto" Margin="0,0,0,12">
            <TextBlock Grid.Column="0" Text="Experiment History"
                       FontSize="20" FontWeight="Bold" VerticalAlignment="Center"/>
            <TextBlock Grid.Column="2" Text="{Binding StatusMessage}"
                       VerticalAlignment="Center" Opacity="0.6" FontSize="12" Margin="12,0"/>
            <Button Grid.Column="3" Content="Refresh" Command="{Binding RefreshCommand}"/>
        </Grid>

        <!-- Three-column layout -->
        <Grid Grid.Row="1" ColumnDefinitions="200,*,*">

            <!-- Dataset selector -->
            <DockPanel Grid.Column="0" Margin="0,0,12,0">
                <TextBlock DockPanel.Dock="Top" Text="Dataset" FontWeight="SemiBold" Margin="0,0,0,4"/>
                <ListBox ItemsSource="{Binding Datasets}"
                         SelectedItem="{Binding SelectedDataset}">
                    <ListBox.ItemTemplate>
                        <DataTemplate x:DataType="domain:Dataset">
                            <StackPanel Margin="2,3">
                                <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="12"/>
                                <TextBlock Text="{Binding QueryCount, StringFormat='{}{0} queries'}"
                                           FontSize="10" Opacity="0.6"/>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </DockPanel>

            <!-- Leaderboard -->
            <DockPanel Grid.Column="1" Margin="0,0,12,0">
                <TextBlock DockPanel.Dock="Top" Text="Model Leaderboard"
                           FontWeight="SemiBold" Margin="0,0,0,4"/>
                <Border BorderBrush="Gray" BorderThickness="1" CornerRadius="4">
                    <StackPanel>
                        <Grid ColumnDefinitions="*,90,90,80,100" Background="#1A000000" Margin="4">
                            <TextBlock Grid.Column="0" Text="Model"    FontWeight="Bold" Margin="4,2" FontSize="11"/>
                            <TextBlock Grid.Column="1" Text="NDCG@10" FontWeight="Bold" Margin="4,2" FontSize="11"/>
                            <TextBlock Grid.Column="2" Text="MRR@10"  FontWeight="Bold" Margin="4,2" FontSize="11"/>
                            <TextBlock Grid.Column="3" Text="MAP"     FontWeight="Bold" Margin="4,2" FontSize="11"/>
                            <TextBlock Grid.Column="4" Text="P50 (ms)" FontWeight="Bold" Margin="4,2" FontSize="11"/>
                        </Grid>
                        <ListBox ItemsSource="{Binding Leaderboard}"
                                 SelectedItem="{Binding SelectedLeaderboardEntry}"
                                 SelectionMode="Single">
                            <ListBox.ItemTemplate>
                                <DataTemplate x:DataType="domain:LeaderboardEntry">
                                    <Grid ColumnDefinitions="*,90,90,80,100" Margin="0">
                                        <TextBlock Grid.Column="0" Text="{Binding ModelLabel}"
                                                   FontSize="11" Margin="4,3" TextWrapping="NoWrap"/>
                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding Ndcg10,      StringFormat=F4}"
                                                   FontSize="11" Margin="4,3"/>
                                        <TextBlock Grid.Column="2"
                                                   Text="{Binding MrrAt10,     StringFormat=F4}"
                                                   FontSize="11" Margin="4,3"/>
                                        <TextBlock Grid.Column="3"
                                                   Text="{Binding MapScore,    StringFormat=F4}"
                                                   FontSize="11" Margin="4,3"/>
                                        <TextBlock Grid.Column="4"
                                                   Text="{Binding LatencyP50Ms,StringFormat=F1}"
                                                   FontSize="11" Margin="4,3"/>
                                    </Grid>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </StackPanel>
                </Border>
            </DockPanel>

            <!-- NDCG trend chart -->
            <DockPanel Grid.Column="2">
                <TextBlock DockPanel.Dock="Top" Text="NDCG@10 Trend"
                           FontWeight="SemiBold" Margin="0,0,0,4"/>
                <Border BorderBrush="Gray" BorderThickness="1" CornerRadius="4" Padding="8">
                    <StackPanel>

                        <!-- Chart -->
                        <Canvas Width="510" Height="190"
                                IsVisible="{Binding HasTrendData}">
                            <!-- Y-axis -->
                            <shapes:Line StartPoint="40,5" EndPoint="40,160"
                                         Stroke="Gray" StrokeThickness="1"/>
                            <!-- X-axis -->
                            <shapes:Line StartPoint="40,160" EndPoint="500,160"
                                         Stroke="Gray" StrokeThickness="1"/>
                            <!-- Axis labels -->
                            <TextBlock Canvas.Left="2" Canvas.Top="3"
                                       Text="{Binding TrendYMaxLabel}" FontSize="9" Opacity="0.7"/>
                            <TextBlock Canvas.Left="2" Canvas.Top="150"
                                       Text="{Binding TrendYMinLabel}" FontSize="9" Opacity="0.7"/>
                            <TextBlock Canvas.Left="180" Canvas.Top="165"
                                       Text="← runs (oldest to newest) →" FontSize="9" Opacity="0.5"/>
                            <TextBlock Canvas.Left="2" Canvas.Top="60"
                                       Text="NDCG" FontSize="9" Opacity="0.5"/>
                            <!-- Trend line -->
                            <shapes:Polyline Points="{Binding TrendPolylinePoints}"
                                             Stroke="#4C72B0" StrokeThickness="2"/>
                            <!-- Dots -->
                            <ItemsControl ItemsSource="{Binding TrendDots}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <Canvas Width="510" Height="190"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="vm:TrendDot">
                                        <shapes:Ellipse Width="8" Height="8" Fill="#4C72B0"
                                                        ToolTip.Tip="{Binding RunName}"
                                                        Canvas.Left="{Binding CanvasX}"
                                                        Canvas.Top="{Binding CanvasY}"/>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Canvas>

                        <!-- Placeholder when no model selected -->
                        <TextBlock Text="Select a model from the leaderboard to see its NDCG trend"
                                   FontSize="11" Opacity="0.5" HorizontalAlignment="Center"
                                   Margin="0,40"
                                   IsVisible="{Binding !HasTrendData}"/>

                        <!-- Run count -->
                        <TextBlock Text="{Binding TrendRunCountLabel}"
                                   FontSize="11" Opacity="0.6" HorizontalAlignment="Right"
                                   IsVisible="{Binding HasTrendData}"/>
                    </StackPanel>
                </Border>
            </DockPanel>

        </Grid>
    </Grid>
</UserControl>
