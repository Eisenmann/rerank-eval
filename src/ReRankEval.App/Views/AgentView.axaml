<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:ReRankEval.App.ViewModels"
             xmlns:domain="using:ReRankEval.Domain.Models"
             xmlns:ctrl="using:ReRankEval.App.Controls"
             x:Class="ReRankEval.App.Views.AgentView"
             x:DataType="vm:AgentViewModel">

    <Grid ColumnDefinitions="180,*,240">

        <!-- Sessions sidebar -->
        <DockPanel Grid.Column="0" Margin="0,0,4,0">
            <Button DockPanel.Dock="Top"
                    Content="+ New Session"
                    Command="{Binding NewSessionCommand}"
                    HorizontalAlignment="Stretch"
                    Margin="4,8,4,4"/>
            <TextBlock DockPanel.Dock="Top"
                       Text="SESSIONS" Foreground="#888" FontSize="10"
                       Margin="8,4,8,4" LetterSpacing="1"/>
            <Border BorderBrush="Gray" BorderThickness="0,1,0,0">
                <ScrollViewer>
                    <ItemsControl ItemsSource="{Binding Sessions}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="domain:AgentSession">
                                <Button HorizontalAlignment="Stretch"
                                        HorizontalContentAlignment="Left"
                                        Margin="2,1"
                                        Padding="6,4"
                                        Command="{Binding $parent[UserControl].((vm:AgentViewModel)DataContext).SelectSessionCommand}"
                                        CommandParameter="{Binding}">
                                    <StackPanel>
                                        <TextBlock Text="{Binding Title}" FontSize="12"
                                                   TextTrimming="CharacterEllipsis" MaxWidth="150"/>
                                        <TextBlock Text="{Binding LastActiveAt, StringFormat='{}{0:MM/dd HH:mm}'}"
                                                   FontSize="10" Opacity="0.6"/>
                                    </StackPanel>
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Border>
        </DockPanel>

        <!-- Chat area -->
        <Grid Grid.Column="1" RowDefinitions="*,Auto" Margin="4,0">

            <Border Grid.Row="0" BorderBrush="Gray" BorderThickness="1" CornerRadius="4">
                <ScrollViewer>
                    <StackPanel Margin="8" Spacing="6">

                        <!-- Message history -->
                        <ItemsControl ItemsSource="{Binding Messages}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="vm:AgentMessageItem">
                                    <Border Padding="10,8" CornerRadius="6" Margin="0,2"
                                            Background="#14000000">
                                        <StackPanel Spacing="4">
                                            <StackPanel Orientation="Horizontal" Spacing="6">
                                                <TextBlock Text="{Binding Role}"
                                                           FontSize="11" FontWeight="SemiBold" Opacity="0.6"/>
                                                <TextBlock Text="{Binding Timestamp, StringFormat='{}{0:HH:mm}'}"
                                                           FontSize="11" Opacity="0.4"/>
                                            </StackPanel>
                                            <ctrl:MarkdownViewer Text="{Binding Content}"/>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <!-- Streaming bubble -->
                        <Border IsVisible="{Binding IsStreaming}"
                                Padding="10,8" CornerRadius="6" Margin="0,2"
                                Background="#0D0080FF">
                            <StackPanel Spacing="4">
                                <TextBlock Text="Assistant (typing…)"
                                           FontSize="11" FontWeight="SemiBold" Opacity="0.6"/>
                                <TextBlock Text="{Binding StreamingText}" TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>

                    </StackPanel>
                </ScrollViewer>
            </Border>

            <!-- Input -->
            <Grid Grid.Row="1" ColumnDefinitions="*,Auto" Margin="0,6,0,0">
                <TextBox Grid.Column="0"
                         Text="{Binding UserInput}"
                         Watermark="Ask the agent (e.g. Compare models on my dataset…)"
                         Margin="0,0,6,0"/>
                <Button Grid.Column="1"
                        Content="Send"
                        Command="{Binding SendCommand}"
                        IsEnabled="{Binding !IsSending}"
                        MinWidth="60"/>
            </Grid>
        </Grid>

        <!-- Action log -->
        <DockPanel Grid.Column="2" Margin="4,0,0,0">
            <TextBlock DockPanel.Dock="Top" Text="Action Log"
                       FontWeight="SemiBold" Margin="0,8,0,4"/>
            <Border BorderBrush="Gray" BorderThickness="1" CornerRadius="4">
                <ScrollViewer>
                    <ItemsControl ItemsSource="{Binding ActionLog}" Margin="4">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="domain:AgentAction">
                                <Border Margin="0,2" Padding="6,4"
                                        Background="#12000000" CornerRadius="4">
                                    <StackPanel Spacing="2">
                                        <TextBlock Text="{Binding ToolName}"
                                                   FontWeight="SemiBold" FontSize="12"
                                                   TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Text="{Binding Status}"
                                                   FontSize="11" Opacity="0.7"/>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Border>
        </DockPanel>

    </Grid>
</UserControl>
