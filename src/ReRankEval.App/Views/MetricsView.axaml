<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:ReRankEval.App.ViewModels"
             xmlns:shapes="using:Avalonia.Controls.Shapes"
             x:Class="ReRankEval.App.Views.MetricsView"
             x:DataType="vm:MetricsViewModel">

    <Grid RowDefinitions="Auto,Auto,*,Auto" Margin="16">

        <!-- Title -->
        <TextBlock Grid.Row="0" Text="Metrics" FontSize="20" FontWeight="Bold" Margin="0,0,0,12"/>

        <!-- Run selector + export -->
        <Grid Grid.Row="1" ColumnDefinitions="Auto,*,Auto,Auto,Auto" Margin="0,0,0,10">
            <TextBlock Grid.Column="0" Text="Run:" VerticalAlignment="Center" Margin="0,0,8,0"/>
            <ComboBox Grid.Column="1" ItemsSource="{Binding Runs}"
                      SelectedItem="{Binding SelectedRun}"
                      HorizontalAlignment="Stretch">
                <ComboBox.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding Name}"/>
                    </DataTemplate>
                </ComboBox.ItemTemplate>
            </ComboBox>
            <Button Grid.Column="2" Content="Refresh"     Command="{Binding RefreshCommand}" Margin="8,0,0,0"/>
            <Button Grid.Column="3" Content="Export CSV"  Click="OnExportCsvClick"
                    IsEnabled="{Binding HasChartData}"     Margin="4,0,0,0"/>
            <Button Grid.Column="4" Content="Export JSON" Click="OnExportJsonClick"
                    IsEnabled="{Binding HasChartData}"     Margin="4,0,0,0"/>
        </Grid>

        <!-- Main content -->
        <ScrollViewer Grid.Row="2">
            <StackPanel Spacing="16">

                <!-- Metrics table -->
                <Border BorderBrush="Gray" BorderThickness="1" CornerRadius="4">
                    <StackPanel>
                        <Grid ColumnDefinitions="*,110,110,80,100,100"
                              Background="#1A000000" Margin="4">
                            <TextBlock Grid.Column="0" Text="Model"     FontWeight="Bold" Margin="4,2"/>
                            <TextBlock Grid.Column="1" Text="NDCG@10"   FontWeight="Bold" Margin="4,2"/>
                            <TextBlock Grid.Column="2" Text="MRR@10"    FontWeight="Bold" Margin="4,2"/>
                            <TextBlock Grid.Column="3" Text="MAP"       FontWeight="Bold" Margin="4,2"/>
                            <TextBlock Grid.Column="4" Text="P50 (ms)"  FontWeight="Bold" Margin="4,2"/>
                            <TextBlock Grid.Column="5" Text="P90 (ms)"  FontWeight="Bold" Margin="4,2"/>
                        </Grid>
                        <ListBox ItemsSource="{Binding MetricRows}"
                                 SelectedItem="{Binding SelectedMetricRow}"
                                 SelectionMode="Single">
                            <ListBox.ItemTemplate>
                                <DataTemplate x:DataType="vm:ModelMetricRow">
                                    <Grid ColumnDefinitions="*,110,110,80,100,100"
                                          Background="{Binding RowBackground}" Margin="0">
                                        <TextBlock Grid.Column="0" Text="{Binding ModelId}"
                                                   Margin="4,3"/>
                                        <TextBlock Grid.Column="1" Text="{Binding Ndcg10, StringFormat=F4}" Margin="4,3"/>
                                        <TextBlock Grid.Column="2" Text="{Binding Mrr10,  StringFormat=F4}" Margin="4,3"/>
                                        <TextBlock Grid.Column="3" Text="{Binding Map,    StringFormat=F4}" Margin="4,3"/>
                                        <TextBlock Grid.Column="4" Text="{Binding P50Ms,  StringFormat=F1}" Margin="4,3"/>
                                        <TextBlock Grid.Column="5" Text="{Binding P90Ms,  StringFormat=F1}" Margin="4,3"/>
                                    </Grid>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </StackPanel>
                </Border>

                <!-- Charts (visible once data loaded) -->
                <Grid ColumnDefinitions="*,*" IsVisible="{Binding HasChartData}">

                    <!-- Scatter plot: Quality vs Latency -->
                    <Border Grid.Column="0" BorderBrush="Gray" BorderThickness="1"
                            CornerRadius="4" Padding="8" Margin="0,0,8,0">
                        <StackPanel>
                            <TextBlock Text="Quality vs. Latency" FontWeight="SemiBold" Margin="0,0,0,4"/>
                            <Canvas Width="430" Height="240">
                                <!-- Axes -->
                                <shapes:Line StartPoint="45,10" EndPoint="45,200"
                                             Stroke="Gray" StrokeThickness="1"/>
                                <shapes:Line StartPoint="45,200" EndPoint="395,200"
                                             Stroke="Gray" StrokeThickness="1"/>
                                <!-- Axis labels -->
                                <TextBlock Canvas.Left="2"   Canvas.Top="5"
                                           Text="{Binding ScatterYMaxLabel}" FontSize="9" Opacity="0.7"/>
                                <TextBlock Canvas.Left="2"   Canvas.Top="193"
                                           Text="{Binding ScatterYMinLabel}" FontSize="9" Opacity="0.7"/>
                                <TextBlock Canvas.Left="45"  Canvas.Top="207"
                                           Text="{Binding ScatterXMinLabel}" FontSize="9" Opacity="0.7"/>
                                <TextBlock Canvas.Left="350" Canvas.Top="207"
                                           Text="{Binding ScatterXMaxLabel}" FontSize="9" Opacity="0.7"/>
                                <TextBlock Canvas.Left="160" Canvas.Top="218"
                                           Text="P50 Latency →" FontSize="9" Opacity="0.5"/>
                                <TextBlock Canvas.Left="2" Canvas.Top="80"
                                           Text="NDCG@10" FontSize="9" Opacity="0.5"/>
                                <!-- Data points -->
                                <ItemsControl ItemsSource="{Binding ScatterPoints}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <Canvas Width="430" Height="240"/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="vm:ScatterPoint">
                                            <Canvas>
                                                <shapes:Ellipse Width="10" Height="10" Fill="#4C72B0"
                                                                Canvas.Left="{Binding CanvasX}"
                                                                Canvas.Top="{Binding CanvasY}"/>
                                                <TextBlock Text="{Binding ShortLabel}" FontSize="9"
                                                           Canvas.Left="{Binding LabelX}"
                                                           Canvas.Top="{Binding LabelY}"/>
                                            </Canvas>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </Canvas>
                        </StackPanel>
                    </Border>

                    <!-- Histogram: per-query NDCG@10 distribution -->
                    <Border Grid.Column="1" BorderBrush="Gray" BorderThickness="1"
                            CornerRadius="4" Padding="8" Margin="8,0,0,0">
                        <StackPanel>
                            <TextBlock Text="NDCG@10 Distribution (select a model row)"
                                       FontWeight="SemiBold" Margin="0,0,0,4" FontSize="12"/>
                            <Canvas Width="400" Height="195"
                                    IsVisible="{Binding HasHistogramData}">
                                <!-- Y-axis -->
                                <shapes:Line StartPoint="40,5" EndPoint="40,155"
                                             Stroke="Gray" StrokeThickness="1"/>
                                <!-- X-axis -->
                                <shapes:Line StartPoint="40,155" EndPoint="390,155"
                                             Stroke="Gray" StrokeThickness="1"/>
                                <TextBlock Canvas.Left="2"  Canvas.Top="2"
                                           Text="{Binding HistogramMaxLabel}" FontSize="9" Opacity="0.7"/>
                                <TextBlock Canvas.Left="140" Canvas.Top="162"
                                           Text="NDCG@10 per query" FontSize="9" Opacity="0.5"/>
                                <!-- Bars -->
                                <ItemsControl ItemsSource="{Binding HistogramBins}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <Canvas Width="400" Height="195"/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="vm:HistogramBin">
                                            <Canvas>
                                                <shapes:Rectangle Fill="#5471B0"
                                                                   Canvas.Left="{Binding BarX}"
                                                                   Canvas.Top="{Binding BarTop}"
                                                                   Width="29"
                                                                   Height="{Binding BarHeight}"/>
                                                <TextBlock Text="{Binding RangeLabel}" FontSize="8"
                                                           Canvas.Left="{Binding LabelX}"
                                                           Canvas.Top="157"/>
                                            </Canvas>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </Canvas>
                            <TextBlock Text="Select a model row above to see distribution"
                                       FontSize="11" Opacity="0.5" HorizontalAlignment="Center"
                                       Margin="0,30"
                                       IsVisible="{Binding !HasHistogramData}"/>
                        </StackPanel>
                    </Border>
                </Grid>

            </StackPanel>
        </ScrollViewer>

        <!-- Error -->
        <TextBlock Grid.Row="3" Text="{Binding ErrorMessage}" Foreground="Red" Margin="0,8,0,0"
                   IsVisible="{Binding ErrorMessage,
                       Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
    </Grid>
</UserControl>
