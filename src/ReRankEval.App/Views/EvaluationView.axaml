<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:ReRankEval.App.ViewModels"
             x:Class="ReRankEval.App.Views.EvaluationView"
             x:DataType="vm:EvaluationViewModel">

    <Grid RowDefinitions="Auto,*,Auto" Margin="16">
        <TextBlock Grid.Row="0" Text="Evaluation" FontSize="20" FontWeight="Bold" Margin="0,0,0,12"/>

        <ScrollViewer Grid.Row="1">
            <StackPanel Spacing="12">

                <!-- Run name -->
                <StackPanel>
                    <TextBlock Text="Run Name" FontWeight="SemiBold"/>
                    <TextBox Text="{Binding RunName}"/>
                </StackPanel>

                <!-- Dataset selector -->
                <StackPanel>
                    <TextBlock Text="Dataset" FontWeight="SemiBold"/>
                    <ComboBox ItemsSource="{Binding Datasets}"
                              SelectedItem="{Binding SelectedDataset}"
                              HorizontalAlignment="Stretch">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Name}"/>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                </StackPanel>

                <!-- Models -->
                <StackPanel>
                    <TextBlock Text="Models to evaluate" FontWeight="SemiBold"/>
                    <Grid ColumnDefinitions="*,8,*">
                        <DockPanel Grid.Column="0">
                            <TextBlock DockPanel.Dock="Top" Text="Available" FontSize="12" Margin="0,0,0,4"/>
                            <ListBox ItemsSource="{Binding AvailableModels}" SelectionMode="Single">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding HuggingFaceId}"/>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </DockPanel>
                        <DockPanel Grid.Column="2">
                            <TextBlock DockPanel.Dock="Top" Text="Selected" FontSize="12" Margin="0,0,0,4"/>
                            <ListBox ItemsSource="{Binding SelectedModels}" SelectionMode="Single">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding HuggingFaceId}"/>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </DockPanel>
                    </Grid>
                </StackPanel>

                <!-- Config -->
                <Grid ColumnDefinitions="*,8,*,8,*">
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="K values (comma-separated)" FontWeight="SemiBold"/>
                        <TextBox Text="{Binding KValues}"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Batch size" FontWeight="SemiBold"/>
                        <NumericUpDown Value="{Binding BatchSize}" Minimum="1" Maximum="64"/>
                    </StackPanel>
                    <StackPanel Grid.Column="4">
                        <TextBlock Text="Execution provider" FontWeight="SemiBold"/>
                        <ComboBox ItemsSource="{Binding Providers}"
                                  SelectedItem="{Binding SelectedProvider}"
                                  HorizontalAlignment="Stretch"/>
                    </StackPanel>
                </Grid>

                <!-- Progress -->
                <StackPanel IsVisible="{Binding IsRunning}">
                    <TextBlock Text="{Binding ProgressText}"/>
                    <ProgressBar Value="{Binding Progress}" Maximum="100" Height="8" Margin="0,4,0,0"/>
                </StackPanel>

                <!-- Error -->
                <TextBlock Text="{Binding ErrorMessage}" Foreground="Red"
                           IsVisible="{Binding ErrorMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>

                <!-- Run history -->
                <TextBlock Text="Run History" FontWeight="SemiBold"/>
                <ListBox ItemsSource="{Binding RunHistory}"
                         SelectedItem="{Binding SelectedRun}"
                         MaxHeight="200">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid ColumnDefinitions="*,Auto">
                                <TextBlock Grid.Column="0" Text="{Binding Name}"/>
                                <TextBlock Grid.Column="1" Text="{Binding Status}" FontSize="11" Opacity="0.7"/>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </StackPanel>
        </ScrollViewer>

        <!-- Buttons -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="8" Margin="0,12,0,0">
            <Button Content="Run Evaluation"
                    Command="{Binding RunEvaluationCommand}"
                    IsEnabled="{Binding !IsRunning}"/>
            <Button Content="Cancel"
                    Command="{Binding CancelRunCommand}"
                    IsVisible="{Binding IsRunning}"/>
            <Button Content="Refresh" Command="{Binding RefreshCommand}"/>
        </StackPanel>
    </Grid>
</UserControl>
