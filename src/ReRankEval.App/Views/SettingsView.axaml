<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:ReRankEval.App.ViewModels"
             x:Class="ReRankEval.App.Views.SettingsView"
             x:DataType="vm:SettingsViewModel">

    <ScrollViewer>
        <StackPanel MaxWidth="560" Margin="32,24" Spacing="12">

            <TextBlock Text="Settings" FontSize="22" FontWeight="Bold" Margin="0,0,0,8"/>

            <!-- LLM Provider -->
            <TextBlock Text="LLM Provider" FontWeight="SemiBold"/>
            <ComboBox ItemsSource="{Binding Providers}"
                      SelectedItem="{Binding LlmProvider}"
                      HorizontalAlignment="Stretch"/>

            <!-- API Key (hidden for Ollama) -->
            <TextBlock Text="API Key" FontWeight="SemiBold"
                       IsVisible="{Binding ShowApiKey}"/>
            <TextBox Text="{Binding ApiKey}"
                     PasswordChar="•"
                     Watermark="Paste your API key here"
                     IsVisible="{Binding ShowApiKey}"/>

            <!-- Model ID -->
            <TextBlock Text="Model ID" FontWeight="SemiBold"/>
            <TextBox Text="{Binding ModelId}"
                     Watermark="e.g. gpt-4o-mini"/>

            <!-- Azure OpenAI specific -->
            <TextBlock Text="Azure Endpoint" FontWeight="SemiBold"
                       IsVisible="{Binding IsAzure}"/>
            <TextBox Text="{Binding AzureEndpoint}"
                     Watermark="https://your-resource.openai.azure.com/"
                     IsVisible="{Binding IsAzure}"/>

            <TextBlock Text="Azure Deployment Name" FontWeight="SemiBold"
                       IsVisible="{Binding IsAzure}"/>
            <TextBox Text="{Binding AzureDeploymentName}"
                     Watermark="your-deployment-name"
                     IsVisible="{Binding IsAzure}"/>

            <!-- Ollama note -->
            <Border Background="#1A0080FF" CornerRadius="4" Padding="10,8"
                    IsVisible="{Binding !ShowApiKey}">
                <TextBlock TextWrapping="Wrap" Opacity="0.8">
                    Ollama: Make sure Ollama is running on localhost:11434 and the model is pulled.
                    No API key required.
                </TextBlock>
            </Border>

            <!-- Actions -->
            <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,8,0,0">
                <Button Content="Test Configuration"
                        Command="{Binding TestConnectionCommand}"
                        IsEnabled="{Binding !IsBusy}"/>
                <Button Content="Save Settings"
                        Command="{Binding SaveCommand}"
                        IsEnabled="{Binding !IsBusy}"/>
            </StackPanel>

            <!-- Status -->
            <TextBlock Text="{Binding StatusMessage}"
                       TextWrapping="Wrap"
                       IsVisible="{Binding StatusMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>

        </StackPanel>
    </ScrollViewer>
</UserControl>
